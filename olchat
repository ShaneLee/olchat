def handle_slash(cmd: str) -> bool:
    """
    Handle /commands typed by the user.
    Returns True if handled (skip sending to model), False otherwise.
    Note: cmd has the leading '/' already stripped by caller.
    """
    parts = cmd.strip().split(None, 1)
    name  = parts[0].lower()
    arg   = parts[1] if len(parts) > 1 else ""

    if name == "perms":
        list_permissions()
        return True

    if name == "revoke":
        if arg:
            revoke_permission(arg)
        else:
            print("Usage: /revoke <key>  e.g. /revoke shell:git commit")
        return True

    if name == "tasks":
        print()
        print_tasks()
        print()
        return True

    if name == "skills":
        print()
        print_skills()
        return True

    if name == "skill":
        # /skill <name>  — print the full body of a named skill
        if not arg:
            print("  Usage: /skill <name>")
        else:
            s = find_skill(arg.strip())
            if s:
                print(f"\n  Skill: {s['name']} — {s['description']}")
                print(f"  Triggers: {', '.join(s['triggers']) or '(none)'}")
                print(f"  File: {s['path']}\n")
                print(s['body'])
                print()
            else:
                print(f"  [skill {arg.strip()!r} not found in {SKILLS_DIR}]")
        return True

    if name == "help":
        print("""
  Slash commands:
    /perms              — list current permissions
    /revoke <key>       — revoke a permission (e.g. /revoke shell:ls)
    /tasks              — show task queue
    /skills             — list available skills (~/.skills/)
    /skill <name>       — show a skill's full content
    /help               — this message

  @ references (interactive mode):
    @<filename>         — attach file(s) via fzf (doesn't submit, allows more input)
    @@                  — literal @
    @skill:name         — inject a skill into the conversation
    
  Examples:
    You: summarise @          (opens fzf, then continues accepting input)
    You: compare @ vs @       (pick two files, continue editing)
    You: explain @ and add @  (add multiple files before sending)
""")
        return True

    return False


# ═══════════════════════════════════════════════════════════════════════════════
# ^Z  (SIGTSTP) support
# ═══════════════════════════════════════════════════════════════════════════════

def _suspend_to_shell() -> None:
    """
    Cleanly suspend the process on ^Z and restore it when foregrounded again.

    Steps:
      1. Save the current terminal attributes (so readline state is not lost).
      2. Print a newline so the shell prompt appears on a fresh line.
      3. Reset the terminal to sane defaults (cooked mode) so the parent
         shell is usable while we are suspended.
      4. Send SIGSTOP to ourselves -- the kernel suspends us here.
         Execution resumes at the line after os.kill() when the shell runs fg.
      5. Restore our saved terminal attributes so readline works again.
      6. Reprint the prompt so the user can see where they are.
    """
    fd = sys.stdin.fileno()
    try:
        saved = termios.tcgetattr(fd)
    except termios.error:
        # Not a real tty (e.g. piped input) -- just stop without fuss
        os.kill(os.getpid(), signal.SIGSTOP)
        return

    try:
        # Reset terminal to cooked mode for the parent shell
        cooked = termios.tcgetattr(fd)
        cooked[3] |= termios.ECHO | termios.ICANON   # lflags: re-enable echo + canonical
        termios.tcsetattr(fd, termios.TCSADRAIN, cooked)

        # Move to a clean line before suspending
        sys.stdout.write("\n")
        sys.stdout.flush()

        # Actually suspend -- resumes here when `fg` is run
        os.kill(os.getpid(), signal.SIGSTOP)

        # Restore our terminal state
        termios.tcsetattr(fd, termios.TCSADRAIN, saved)

        # Reprint the prompt so the user knows where they are
        sys.stdout.write("You: ")
        sys.stdout.flush()

    except Exception:
        # Never crash on signal-handling weirdness
        try:
            termios.tcsetattr(fd, termios.TCSADRAIN, saved)
        except Exception:
            pass


def _install_sigtstp(handler) -> None:
    """Install SIGTSTP handler, silently skip on platforms that lack it (Windows)."""
    if hasattr(signal, "SIGTSTP"):
        signal.signal(signal.SIGTSTP, handler)


def _open_in_editor(initial_content: str = "") -> str | None:
    """
    Open a temporary file in the user's $EDITOR and return the edited content.
    Returns None if editor fails or is cancelled.
    """
    editor = os.environ.get("EDITOR", "vim")
    
    try:
        with tempfile.NamedTemporaryFile(mode="w", suffix=".txt", delete=False) as f:
            f.write(initial_content)
            temp_path = f.name
        
        # Open the file in the editor
        result = subprocess.run([editor, temp_path], check=False)
        
        if result.returncode == 0:
            try:
                return Path(temp_path).read_text(encoding="utf-8")
            except Exception as e:
                print(f"\n  [error reading edited file: {e}]")
                return None
        else:
            return None
    except Exception as e:
        print(f"\n  [error opening editor: {e}]")
        return None
    finally:
        try:
            Path(temp_path).unlink()
        except Exception:
            pass


def prompt_line(prompt_text: str = "You: ") -> str:
    """
    Drop-in replacement for input() that keeps ^Z working.
    Reinstalls the SIGTSTP handler before every readline call because
    some readline builds reset signal dispositions internally.
    """
    def _tstp_handler(signum, frame):
        _suspend_to_shell()
        # Reinstall after resume so ^Z keeps working next time
        _install_sigtstp(_tstp_handler)

    _install_sigtstp(_tstp_handler)

    return input(prompt_text)


def prompt_line_with_at_support(prompt_text: str = "You: ") -> str:
    """
    Interactive prompt that handles @ for file picking inline and ^E for editor.
    When user types @, fzf opens to select a file, then continues prompting.
    When user presses ^E, opens current input in $EDITOR.
    Allows multiple @ references and additional typing after each selection.
    """
    def _tstp_handler(signum, frame):
        _suspend_to_shell()
        _install_sigtstp(_tstp_handler)

    _install_sigtstp(_tstp_handler)

    print(Colors.wrap(prompt_text, Colors.CYAN), end="", flush=True)
    full_input = ""

    try:
        while True:
            try:
                user_line = _read_line_with_editor_support()
            except EOFError:
                if full_input:
                    return full_input
                raise
            except KeyboardInterrupt:
                if full_input:
                    # Mid-message cancel: clear accumulated input and redraw prompt
                    full_input = ""
                    print()
                    print(Colors.wrap(prompt_text, Colors.CYAN), end="", flush=True)
                    continue
                else:
                    # Nothing typed yet: propagate so the main loop can catch it
                    raise

            processed = ""
            i = 0
            found_at = False

            while i < len(user_line):
                ch = user_line[i]

                # Check for @ file reference (but not @@)
                if ch == "@" and (i + 1 >= len(user_line) or user_line[i + 1] != "@"):
                    found_at = True

                    # Extract hint (text after @ until whitespace)
                    j = i + 1
                    while j < len(user_line) and not user_line[j].isspace():
                        j += 1

                    hint = user_line[i + 1:j]

                    print()
                    chosen = pick_file(hint)

                    if chosen is None:
                        # User cancelled or no file selected
                        processed += user_line[i:j]
                        i = j

                    else:
                        p = Path(chosen)

                        if not p.exists():
                            print(f"  [warning: {chosen!r} not found, skipping]")
                            processed += user_line[i:j]
                            i = j
                        else:
                            # Commit everything accumulated so far,
                            # including the attached file reference.
                            processed += chosen
                            full_input += processed

                            print(f"  [attached: {chosen}]")

                            processed = ""
                            i = j

                elif ch == "@" and i + 1 < len(user_line) and user_line[i + 1] == "@":
                    # Escaped @ → literal @
                    processed += "@"
                    i += 2

                else:
                    processed += ch
                    i += 1

            # Add any remaining text from this line
            full_input += processed

            # If @ references were processed, redraw once and continue editing
            if found_at:
                print()
                print(prompt_text + full_input, end="", flush=True)
                continue

            # No @ references: input is complete
            return full_input

    except EOFError:
        return full_input if full_input else ""

def _read_line_with_editor_support(prompt_text: str = "") -> str:
    """
    Read a line from user with support for ^E to open in editor.
    When ^E is pressed, current input is opened in $EDITOR.
    """
    fd = sys.stdin.fileno()
    saved = termios.tcgetattr(fd)
    
    try:
        tty.setraw(fd)
        line = ""
        
        while True:
            ch = sys.stdin.read(1)
            
            if not ch:
                # EOF
                raise EOFError()

            # Ctrl+C: raise KeyboardInterrupt
            elif ch == '\x03':
                termios.tcsetattr(fd, termios.TCSADRAIN, saved)
                raise KeyboardInterrupt()
            
            # Ctrl+E: open in editor
            if ch == '\x05':  # ASCII 5 = Ctrl+E
                print()  # newline
                edited = _open_in_editor(line)
                if edited is not None:
                    termios.tcsetattr(fd, termios.TCSADRAIN, saved)
                    return edited.rstrip('\n')
                else:
                    # Editor cancelled or failed, show current input and continue
                    sys.stdout.write(line)
                    sys.stdout.flush()
                    continue
            
            
            # Ctrl+U: clear line
            elif ch == '\x15':
                line = ""
                sys.stdout.write('\r' + ' ' * 100 + '\r')
                sys.stdout.flush()
                continue
            
            # Backspace / Ctrl+H
            elif ch in ('\x7f', '\x08'):
                if line:
                    line = line[:-1]
                    sys.stdout.write('\b \b')
                    sys.stdout.flush()
                continue
            
            # Enter / Ctrl+J (raw terminal sends \r, not \n)
            elif ch in ('\r', '\n'):
                sys.stdout.write('\n')
                sys.stdout.flush()
                termios.tcsetattr(fd, termios.TCSADRAIN, saved)
                return line
            
            # Printable character
            elif ord(ch) >= 32 and ord(ch) < 127:
                line += ch
                sys.stdout.write(ch)
                sys.stdout.flush()
            
            # Other control characters: ignore
    
    finally:
        try:
            termios.tcsetattr(fd, termios.TCSADRAIN, saved)
        except Exception:
            pass


