def _get_db() -> sqlite3.Connection:
    db = sqlite3.connect(TASKS_DB)
    db.execute("""
        CREATE TABLE IF NOT EXISTS tasks (
            id      INTEGER PRIMARY KEY AUTOINCREMENT,
            title   TEXT NOT NULL,
            detail  TEXT,
            status  TEXT NOT NULL DEFAULT 'pending',
            result  TEXT,
            created TEXT NOT NULL DEFAULT (datetime('now')),
            updated TEXT NOT NULL DEFAULT (datetime('now'))
        )
    """)
    db.commit()
    return db


def task_add(title: str, detail: str = "") -> int:
    db = _get_db()
    cur = db.execute(
        "INSERT INTO tasks (title, detail) VALUES (?, ?)", (title, detail)
    )
    db.commit()
    return cur.lastrowid


def task_done(task_id: int, result: str = "") -> None:
    db = _get_db()
    db.execute(
        "UPDATE tasks SET status='done', result=?, updated=datetime('now') WHERE id=?",
        (result, task_id),
    )
    db.commit()


def task_fail(task_id: int, reason: str = "") -> None:
    db = _get_db()
    db.execute(
        "UPDATE tasks SET status='failed', result=?, updated=datetime('now') WHERE id=?",
        (reason, task_id),
    )
    db.commit()


def task_list_all() -> list[dict]:
    db = _get_db()
    rows = db.execute(
        "SELECT id, title, detail, status, result, created, updated FROM tasks ORDER BY id"
    ).fetchall()
    cols = ["id", "title", "detail", "status", "result", "created", "updated"]
    return [dict(zip(cols, row)) for row in rows]


def task_list_pending() -> list[dict]:
    return [t for t in task_list_all() if t["status"] == "pending"]


def print_tasks() -> None:
    tasks = task_list_all()
    if not tasks:
        print("  (no tasks)")
        return
    status_icons = {"pending": "○", "done": "✓", "failed": "✗"}
    for t in tasks:
        icon = status_icons.get(t["status"], "?")
        print(f"  [{icon}] #{t['id']}  {t['title']}")
        if t["detail"]:
            print(f"         {t['detail'][:80]}")
        if t["result"]:
            print(f"         → {t['result'][:80]}")



