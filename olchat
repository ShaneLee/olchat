def find_latest_transcript(directory: str) -> Path | None:
    """
    Find the most recently modified file in directory that looks like a transcript.
    Heuristic: files with User/model names in content.
    Returns the path or None if no suitable file found.
    """
    dir_path = Path(directory).expanduser().resolve()
    if not dir_path.is_dir():
        return None
    
    candidates = []
    for file_path in dir_path.iterdir():
        if file_path.is_file() and file_path.suffix in {".txt", ".md", ""}:
            try:
                content = file_path.read_text(encoding="utf-8", errors="ignore")
                if "You:" in content or f"{MODEL}:" in content:
                    candidates.append((file_path.stat().st_mtime, file_path))
            except Exception:
                pass
    
    if not candidates:
        return None
    candidates.sort(reverse=True)
    return candidates[0][1]


def parse_transcript(content: str) -> list[dict]:
    """
    Parse a transcript file back into messages.
    Format: "You: <msg>" and "MODEL: <msg>" separated by blank lines.
    Returns list of {"role": "user"|"assistant", "content": "..."} dicts.
    """
    messages = []
    # Split by double newlines to separate exchanges
    exchanges = content.split("\n\n")
    
    for exchange in exchanges:
        exchange = exchange.strip()
        if not exchange:
            continue
        
        lines = exchange.split("\n", 1)
        first_line = lines[0].strip()
        rest = lines[1].strip() if len(lines) > 1 else ""
        
        # Extract metadata lines (lines starting with [)
        content_lines = []
        for line in rest.split("\n"):
            if line.strip().startswith("[") and line.strip().endswith("]"):
                # Skip metadata like [skills: ...], [attached: ...]
                continue
            content_lines.append(line)
        
        msg_content = "\n".join(content_lines).strip()
        
        if first_line.startswith("You:"):
            messages.append({"role": "user", "content": msg_content})
        elif ":" in first_line and first_line.endswith(":"):
            # Model response (e.g., "gemma4:e4b:")
            messages.append({"role": "assistant", "content": msg_content})
    
    return messages


def resume_session(directory: str, file_content: str | None, output_path: str | None,
                   tools: bool) -> None:
    """
    Resume an interactive session from a directory's latest transcript.
    Loads previous messages and continues the conversation.
    """
    global _session_file
    
    transcript_path = find_latest_transcript(directory)
    if transcript_path is None:
        print(f"[No transcript found in {directory}]")
        print("[Starting fresh session instead]\n")
        interactive(file_content, output_path, tools)
        return
    
    # Use the existing transcript as the session file
    _session_file = transcript_path
    print(f"[Resuming from {Colors.wrap(str(transcript_path), Colors.CYAN)}]\n")
    
    transcript_content = transcript_path.read_text(encoding="utf-8", errors="replace")
    previous_messages = parse_transcript(transcript_content)
    
    if not previous_messages:
        print("[Could not parse previous messages]")
        print("[Starting fresh session instead]\n")
        interactive(file_content, output_path, tools)
        return
    
    # Start interactive mode with previous messages loaded
    print(f"Resuming chat with {Colors.wrap(MODEL, Colors.BOLD)}. Type 'exit' or Ctrl-C to quit.")
    print("Tips: use @ to attach files (fzf opens inline), Ctrl+E to edit in $EDITOR")
    print("      type /help for commands")
    if tools:
        print("Tools: shell, write_file, read_file, task_add/done/list are available")
    if file_content:
        print("[File loaded via -f — model has access to its contents]")
    if output_path:
        print(f"[New messages will be appended to {output_path}]")
    print(Colors.wrap("─" * 80, Colors.GREY))
    print(f"[Previous messages loaded: {len(previous_messages)} entries]")
    print(Colors.wrap("─" * 80, Colors.GREY))
    print()
    
    # Build system prompt
    sys_prompt = build_system_prompt(file_content, tools)
    messages: list[dict] = []
    if sys_prompt:
        messages.append({"role": "system", "content": sys_prompt})
    
    # Add previous messages
    messages.extend(previous_messages)
    
    # New transcript parts (for appending)
    transcript_parts: list[str] = []
    
    # Continue the interactive loop
    try:
        while True:
            try:
                raw_input = prompt_line_with_at_support("You: ").strip()
            except EOFError:
                break
            
            if not raw_input:
                continue
            if raw_input.lower() in {"exit", "quit", "q"}:
                break
            if raw_input.startswith("/") and handle_slash(raw_input[1:] if raw_input[1:2] != "/" else raw_input):
                continue
            
            # Expand @skill: refs first, then regular @ file refs
            expanded, skill_list = expand_skill_refs(raw_input)
            expanded, inline_paths = expand_at_refs(expanded)
            
            if skill_list:
                print(f"  [skills: {', '.join(s['name'] for s in skill_list)}]")
            if inline_paths:
                print(f"  [attached: {', '.join(str(p) for p in inline_paths)}]")
            
            # Skills injected as a user-turn context block
            skill_context = ""
            if skill_list:
                skill_context = "\n\n".join(format_skill_block(s) for s in skill_list) + "\n\n"
            
            user_content = skill_context + build_user_message(expanded, inline_paths)
            messages.append({"role": "user", "content": user_content})
            transcript_parts.append(f"You: {expanded}")
            if skill_list:
                transcript_parts.append(f"  [skills: {', '.join(s['name'] for s in skill_list)}]")
            if inline_paths:
                transcript_parts.append(f"  [attached: {', '.join(str(p) for p in inline_paths)}]")
            
            # Save user prompt to session
            metadata = []
            if skill_list:
                metadata.append(f"[skills: {', '.join(s['name'] for s in skill_list)}]")
            if inline_paths:
                metadata.append(f"[attached: {', '.join(str(p) for p in inline_paths)}]")
            _save_to_session("You", expanded, metadata if metadata else None)
            
            print(f"\n{Colors.wrap(MODEL + ':', Colors.GREEN)} ", end="", flush=True)
            reply = stream_chat(messages)
            print()
            print(Colors.wrap("─" * 80, Colors.GREY))
            
            messages.append({"role": "assistant", "content": reply})
            transcript_parts.append(f"{MODEL}: {reply}")
            
            # Save response to session
            _save_to_session(f"{MODEL}", reply)
    
    except KeyboardInterrupt:
        print("\n[interrupted]")
    
    if output_path and transcript_parts:
        # Append to existing output
        try:
            existing = Path(output_path).read_text(encoding="utf-8") + "\n\n"
        except FileNotFoundError:
            existing = ""
        Path(output_path).write_text(existing + "\n\n".join(transcript_parts), encoding="utf-8")
        print(f"\n[appended to → {output_path}]")


# ═══════════════════════════════════════════════════════════════════════════════
# Entry point
# ═══════════════════════════════════════════════════════════════════════════════

def main() -> None:
    global MODEL, OLLAMA_URL

    parser = argparse.ArgumentParser(
        description=f"Chat with {MODEL} via Ollama.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    parser.add_argument("-p", "--prompt",   metavar="TEXT",
                        help="One-shot prompt (omit for interactive mode)")
    parser.add_argument("-f", "--file",     metavar="PATH",
                        help="File to pass as context for the whole session")
    parser.add_argument("-o", "--output",   metavar="PATH",
                        help="File to write the response or transcript to")
    parser.add_argument("--model",          metavar="NAME", default=MODEL,
                        help=f"Ollama model (default: {MODEL})")
    parser.add_argument("--base-url",       metavar="URL",  default=OLLAMA_URL,
                        help=f"Ollama API base URL (default: {OLLAMA_URL})")
    parser.add_argument("--no-tools",       action="store_true",
                        help="Disable tool use (shell, write_file, task_*)")
    parser.add_argument("--tasks",          action="store_true",
                        help="Run all pending tasks from the task DB autonomously")
    parser.add_argument("--add-task",       metavar="TITLE",
                        help="Add a task to the queue and exit")
    parser.add_argument("--list-tasks",     action="store_true",
                        help="Print the task queue and exit")
    parser.add_argument("--perms",          action="store_true",
                        help="Show current permissions and exit")
    parser.add_argument("--resume",         nargs='?', const='.', metavar="DIR",
                        help="Resume a session from the latest transcript (default: current dir)")

    args = parser.parse_args()

    MODEL      = args.model
    OLLAMA_URL = args.base_url.rstrip("/")
    tools      = not args.no_tools

    # ── quick sub-commands ────────────────────────────────────────────────
    if args.perms:
        list_permissions()
        return

    if args.list_tasks:
        print_tasks()
        return

    if args.add_task:
        new_id = task_add(args.add_task)
        print(f"[task #{new_id} added: {args.add_task}]")
        return

    check_model()

    file_content = read_file_safe(args.file) if args.file else None

    if args.tasks:
        run_tasks(tools)
    elif args.prompt:
        one_shot(args.prompt, file_content, args.output, tools)
    elif args.resume:
        resume_session(args.resume, file_content, args.output, tools)
    else:
        interactive(file_content, args.output, tools)


if __name__ == "__main__":
    main()
