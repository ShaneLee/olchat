def _init_session() -> None:
    """Initialize a new session file with timestamp."""
    global _session_file
    SESSIONS_DIR.mkdir(parents=True, exist_ok=True)
    timestamp = time.strftime("%Y%m%d_%H%M%S")
    _session_file = SESSIONS_DIR / f"session_{timestamp}.md"
    # Create empty file
    _session_file.write_text("", encoding="utf-8")
    print(f"  [session → {_session_file}]")


def _save_to_session(message_type: str, content: str, metadata: list[str] | None = None) -> None:
    """
    Save a message (user or assistant) to the session file.
    Runs immediately without threading to ensure data is written.
    """
    if _session_file is None:
        return
    
    with _session_lock:
        try:
            existing = _session_file.read_text(encoding="utf-8", errors="replace")
            
            # Format the message block
            block = f"{message_type}: {content}"
            if metadata:
                block = message_type + "\n" + "\n".join(f"  {m}" for m in metadata) + f"\n\n{content}"
            
            # Add separator between exchanges
            if existing and not existing.endswith("\n\n"):
                existing += "\n\n"
            
            new_content = existing + block + "\n"
            _session_file.write_text(new_content, encoding="utf-8")
        except Exception as e:
            # Silently fail to not disrupt the chat
            pass


