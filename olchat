def one_shot(prompt: str, file_content: str | None, output_path: str | None,
             tools: bool) -> None:
    expanded_prompt, skill_list = expand_skill_refs(prompt)
    expanded_prompt, inline_paths = expand_at_refs(expanded_prompt)
    sys_prompt = build_system_prompt(file_content, tools, active_skills=skill_list)
    messages: list[dict] = []
    if sys_prompt:
        messages.append({"role": "system", "content": sys_prompt})

    if skill_list:
        print(f"[skills: {', '.join(s['name'] for s in skill_list)}]")
    if inline_paths:
        print(f"[attached: {', '.join(str(p) for p in inline_paths)}]")

    messages.append({"role": "user", "content": build_user_message(expanded_prompt, inline_paths)})

    print(f"\n{Colors.wrap(MODEL + ':', Colors.GREEN)} ", end="", flush=True)
    reply = stream_chat(messages)
    print()  # newline after response

    if output_path:
        write_file_safe(output_path, reply)


def interactive(file_content: str | None, output_path: str | None, tools: bool) -> None:
    global _session_file
    
    _init_session()
    
    print(f"Chatting with {Colors.wrap(MODEL, Colors.BOLD)}. Type 'exit' or Ctrl-C to quit.")
    print("Tips: use @ to attach files (fzf opens inline), Ctrl+E to edit in $EDITOR")
    print("      type /help for commands")
    if tools:
        print("Tools: shell, write_file, read_file, task_add/done/list are available")
    if not _fzf_available():
        print("       (install fzf for fuzzy file picking)")
    if file_content:
        print("[File loaded via -f — model has access to its contents]")
    if output_path:
        print(f"[Conversation will be saved to {output_path} on exit]")
    print(Colors.wrap("═" * 80, Colors.GREY))

    sys_prompt = build_system_prompt(file_content, tools)
    messages: list[dict] = []
    if sys_prompt:
        messages.append({"role": "system", "content": sys_prompt})

    transcript_parts: list[str] = []

    try:
        while True:
            try:
                raw_input = prompt_line_with_at_support("You: ").strip()
            except EOFError:
                break

            if not raw_input:
                continue
            if raw_input.lower() in {"exit", "quit", "q"}:
                break
            if raw_input.startswith("/") and handle_slash(raw_input[1:] if raw_input[1:2] != "/" else raw_input):
                continue

            # Expand @skill: refs first, then regular @ file refs
            expanded, skill_list = expand_skill_refs(raw_input)
            expanded, inline_paths = expand_at_refs(expanded)

            if skill_list:
                print(f"  [skills: {', '.join(s['name'] for s in skill_list)}]")
            if inline_paths:
                print(f"  [attached: {', '.join(str(p) for p in inline_paths)}]")

            # Skills injected as a user-turn context block (keeps them out of
            # the system prompt so they don't bloat every subsequent request)
            skill_context = ""
            if skill_list:
                skill_context = "\n\n".join(format_skill_block(s) for s in skill_list) + "\n\n"

            user_content = skill_context + build_user_message(expanded, inline_paths)
            messages.append({"role": "user", "content": user_content})
            transcript_parts.append(f"You: {expanded}")
            if skill_list:
                transcript_parts.append(f"  [skills: {', '.join(s['name'] for s in skill_list)}]")
            if inline_paths:
                transcript_parts.append(f"  [attached: {', '.join(str(p) for p in inline_paths)}]")

            # Save user prompt to session
            metadata = []
            if skill_list:
                metadata.append(f"[skills: {', '.join(s['name'] for s in skill_list)}]")
            if inline_paths:
                metadata.append(f"[attached: {', '.join(str(p) for p in inline_paths)}]")
            _save_to_session("You", expanded, metadata if metadata else None)

            print(f"\n{Colors.wrap(MODEL + ':', Colors.GREEN)} ", end="", flush=True)
            reply = stream_chat(messages)
            print()
            print(Colors.wrap("─" * 80, Colors.GREY))

            messages.append({"role": "assistant", "content": reply})
            transcript_parts.append(f"{MODEL}: {reply}")
            
            # Save response to session
            _save_to_session(f"{MODEL}", reply)

    except KeyboardInterrupt:
        print("\n[interrupted]")

    if output_path and transcript_parts:
        write_file_safe(output_path, "\n\n".join(transcript_parts))


def run_tasks(tools: bool) -> None:
    """
    Autonomous mode: pop pending tasks from the DB and run each one.
    The model gets a fresh context per task, with the task detail as its prompt.
    """
    pending = task_list_pending()
    if not pending:
        print("No pending tasks.")
        return

    print(f"Running {len(pending)} pending task(s)…\n")
    sys_prompt = build_system_prompt(None, tools)

    for task in pending:
        tid   = task["id"]
        title = task["title"]
        detail = task["detail"] or title

        print(f"─── Task #{tid}: {title} {'─' * max(0, 50 - len(title))}")
        messages: list[dict] = []
        if sys_prompt:
            messages.append({"role": "system", "content": sys_prompt})
        messages.append({"role": "user", "content": detail})

        print(f"\n{Colors.wrap(MODEL + ':', Colors.GREEN)} ", end="", flush=True)
        try:
            reply = stream_chat(messages)
            task_done(tid, reply[:200])
            print(f"\n  [task #{tid} marked done]\n")
        except Exception as e:
            task_fail(tid, str(e))
            print(f"\n  [task #{tid} failed: {e}]\n")


