def _fzf_available() -> bool:
    return shutil.which("fzf") is not None


def _pick_file_fzf(prefix: str = "") -> str | None:
    cmd = ["fzf", "--height=40%", "--layout=reverse", "--border",
           "--prompt=📎 file: ", "--preview=cat {}"]
    if prefix:
        cmd += ["--query", prefix]
    try:
        result = subprocess.run(cmd, stdout=subprocess.PIPE, text=True)
        return result.stdout.strip() or None if result.returncode == 0 else None
    except FileNotFoundError:
        return None


def _pick_file_fallback(prefix: str = "") -> str | None:
    try:
        default = f" [{prefix}]" if prefix else ""
        path = input(f"  File path{default}: ").strip() or prefix
        return path or None
    except (EOFError, KeyboardInterrupt):
        return None


def pick_file(prefix: str = "") -> str | None:
    if _fzf_available():
        return _pick_file_fzf(prefix)
    if prefix == "":
        print("  [fzf not found — using plain prompt]")
    return _pick_file_fallback(prefix)


def expand_at_refs(raw: str) -> tuple[str, list[Path]]:
    result_parts: list[str] = []
    resolved:     list[Path] = []
    i = 0
    while i < len(raw):
        ch = raw[i]
        if ch != "@":
            result_parts.append(ch)
            i += 1
            continue
        if i + 1 < len(raw) and raw[i + 1] == "@":
            result_parts.append("@")
            i += 2
            continue
        j = i + 1
        while j < len(raw) and not raw[j].isspace():
            j += 1
        hint = raw[i + 1: j]
        print()
        chosen = pick_file(hint)
        if chosen is None:
            result_parts.append(raw[i:j])
            i = j
            continue
        p = Path(chosen)
        if not p.exists():
            print(f"  [warning: {chosen!r} not found, skipping]")
            result_parts.append(raw[i:j])
            i = j
            continue
        resolved.append(p)
        result_parts.append(chosen)
        i = j
    return "".join(result_parts), resolved


