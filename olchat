def read_file_safe(path: str) -> str:
    p = Path(path)
    if not p.exists():
        sys.exit(f"Error: file not found: {path}")
    return p.read_text(encoding="utf-8", errors="replace")


def write_file_safe(path: str, content: str) -> None:
    Path(path).write_text(content, encoding="utf-8")
    print(f"\n[saved → {path}]")


def format_file_block(path: Path) -> str:
    content = path.read_text(encoding="utf-8", errors="replace")
    return f"--- FILE: {path} ---\n{content}\n--- END: {path} ---"


def build_user_message(text: str, inline_paths: list[Path]) -> str:
    if not inline_paths:
        return text
    blocks = "\n\n".join(format_file_block(p) for p in inline_paths)
    return f"{text}\n\n{blocks}"


def build_system_prompt(file_content: str | None, tools: bool,
                        active_skills: list[dict] | None = None) -> str:
    parts = []
    if tools:
        all_skills = load_all_skills()
        tool_prompt = TOOLS_SYSTEM_PROMPT.strip()
        index = skills_index_prompt(all_skills)
        if index:
            tool_prompt += "\n\n" + index
        parts.append(tool_prompt)
    # Inject any already-active skills (loaded via @skill: or auto-detect)
    if active_skills:
        for skill in active_skills:
            parts.append(format_skill_block(skill))
    if file_content:
        parts.append(
            "The user has provided the following file content.\n\n"
            "--- FILE CONTENT ---\n"
            f"{file_content}\n"
            "--- END OF FILE ---"
        )
    return "\n\n".join(parts) if parts else ""


# ═══════════════════════════════════════════════════════════════════════════════
# Ollama streaming with tool-call loop
# ═══════════════════════════════════════════════════════════════════════════════

def _do_stream(messages: list[dict]) -> str:
    """One raw streaming request → full text response."""
    data = json.dumps({"model": MODEL, "messages": messages, "stream": True}).encode()
    req  = urllib.request.Request(
        f"{OLLAMA_URL}/chat", data=data,
        headers={"Content-Type": "application/json"}, method="POST",
    )

    full: list[str] = []
    spinner = Spinner()
    spinner.start()
    first = True

    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            for raw_line in resp:
                line = raw_line.decode().strip()
                if not line:
                    continue
                try:
                    chunk = json.loads(line)
                except json.JSONDecodeError:
                    continue
                token = chunk.get("message", {}).get("content", "")
                if token:
                    if first:
                        spinner.stop()
                        first = False
                    print(token, end="", flush=True)
                    full.append(token)
                if chunk.get("done"):
                    break
    except urllib.error.URLError as e:
        spinner.stop()
        sys.exit(
            f"Error: cannot reach Ollama at {OLLAMA_URL}\n"
            f"  Make sure `ollama serve` is running.\n  Detail: {e}"
        )
    finally:
        if not spinner._stop_event.is_set():
            spinner.stop()

    print()
    return "".join(full)


def stream_chat(messages: list[dict]) -> str:
    """
    Stream a response.  If the model emits tool calls, execute them and
    feed results back, looping until the model produces a plain reply.
    """
    MAX_TOOL_ROUNDS = 20

    for round_num in range(MAX_TOOL_ROUNDS):
        reply = _do_stream(messages)
        calls = extract_tool_calls(reply)

        if not calls:
            return reply   # plain response — we're done

        # Execute each tool call and collect results
        messages.append({"role": "assistant", "content": reply})

        results_text_parts = []
        for raw_block, call in calls:
            if call.get("tool") == "__parse_error__":
                result = f"[tool parse error: {call.get('error')}]"
            else:
                result = run_tool(call)
            results_text_parts.append(
                f"Tool result for `{call.get('tool', '?')}`:\n{result}"
            )

        tool_results = "\n\n".join(results_text_parts)
        messages.append({"role": "user", "content": tool_results})
        print(f"\n  [tool round {round_num + 1} complete — continuing…]\n")

    return "[max tool rounds reached]"


def ollama_request(endpoint: str, payload: dict) -> dict:
    data = json.dumps(payload).encode()
    req  = urllib.request.Request(
        f"{OLLAMA_URL}/{endpoint}", data=data,
        headers={"Content-Type": "application/json"}, method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=300) as resp:
            return json.loads(resp.read())
    except urllib.error.URLError as e:
        sys.exit(
            f"Error: cannot reach Ollama at {OLLAMA_URL}\n"
            f"  Make sure `ollama serve` is running.\n  Detail: {e}"
        )


def check_model() -> None:
    try:
        result = ollama_request("show", {"name": MODEL})
        if "error" in result:
            print(f"Warning: model '{MODEL}' may not be available. Run: ollama pull {MODEL}")
    except SystemExit:
        pass


# ═══════════════════════════════════════════════════════════════════════════════
# Skills  (~/.skills/)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Skill files live in ~/.skills/<name>.md and have a YAML-like frontmatter block:
#
#   ---
#   name: git
#   description: Git workflow preferences and commit conventions
#   triggers: git, commit, branch, merge, rebase, push, pull request
#   ---
#
#   ... free-form markdown instructions follow ...
#
# Activation:
#   - Explicitly:    @skill:git  in any message
#   - Auto-detect:   model is shown skill index at session start and decides
#   - /skills        list all available skills
# ═══════════════════════════════════════════════════════════════════════════════

import re as _re

_FRONTMATTER_RE = _re.compile(
    r"^---\s*\n(.*?)\n---\s*\n", _re.DOTALL
)
_FIELD_RE = _re.compile(r"^(\w+)\s*:\s*(.+)$", _re.MULTILINE)


def _parse_skill(path: Path) -> dict | None:
    """
    Parse a skill file.  Returns a dict with keys:
      name, description, triggers (list[str]), body (str), path
    Returns None if the file has no valid frontmatter.
    """
    try:
        raw = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        return None

    m = _FRONTMATTER_RE.match(raw)
    if not m:
        return None

    fields: dict[str, str] = {}
    for fm in _FIELD_RE.finditer(m.group(1)):
        fields[fm.group(1).strip().lower()] = fm.group(2).strip()

    if "name" not in fields:
        fields["name"] = path.stem

    body = raw[m.end():]

    triggers_raw = fields.get("triggers", "")
    triggers = [t.strip().lower() for t in triggers_raw.split(",") if t.strip()]

    return {
        "name":        fields["name"],
        "description": fields.get("description", "(no description)"),
        "triggers":    triggers,
        "body":        body.strip(),
        "path":        path,
    }


def load_all_skills() -> list[dict]:
    """Return parsed skill dicts for every valid .md in SKILLS_DIR."""
    if not SKILLS_DIR.exists():
        return []
    skills = []
    for p in sorted(SKILLS_DIR.glob("*.md")):
        s = _parse_skill(p)
        if s:
            skills.append(s)
    return skills


def find_skill(name: str) -> dict | None:
    """Look up a skill by its name field (case-insensitive)."""
    needle = name.strip().lower()
    for s in load_all_skills():
        if s["name"].lower() == needle:
            return s
    return None


def skills_index_prompt(skills: list[dict]) -> str:
    """
    A compact index injected into the system prompt so the model knows
    what skills are available and can ask to load them via tool call.
    """
    if not skills:
        return ""
    lines = ["## Available skills (use `load_skill` tool to activate one)"]
    for s in skills:
        trigger_hint = f"  triggers: {', '.join(s['triggers'])}" if s["triggers"] else ""
        lines.append(f"- **{s['name']}**: {s['description']}{trigger_hint}")
    return "\n".join(lines)


def format_skill_block(skill: dict) -> str:
    return (
        f"--- SKILL: {skill['name']} ---\n"
        f"{skill['body']}\n"
        f"--- END SKILL: {skill['name']} ---"
    )


def print_skills() -> None:
    skills = load_all_skills()
    if not skills:
        print(f"  No skills found in {SKILLS_DIR}")
        print(f"  Create a .md file there with ---frontmatter--- to add one.")
        return
    print(f"  Skills in {SKILLS_DIR}:")
    for s in skills:
        trig = ", ".join(s["triggers"]) if s["triggers"] else "—"
        print(f"    {s['name']:<20} {s['description']}")
        print(f"    {'':20} triggers: {trig}")
    print()


def expand_skill_refs(raw: str) -> tuple[str, list[dict]]:
    """
    Replace @skill:<name> tokens with the skill name (for readability)
    and return the list of resolved skill dicts to be injected into context.
    Unresolved @skill:x refs are left as-is with a warning.
    """
    pattern = _re.compile(r"@skill:(\S+)")
    loaded: list[dict] = []
    seen: set[str] = set()

    def replace(m):
        name = m.group(1)
        if name in seen:
            return f"@skill:{name}"
        seen.add(name)
        skill = find_skill(name)
        if skill is None:
            print(f"  [warning: skill {name!r} not found in {SKILLS_DIR}]")
            return m.group(0)
        loaded.append(skill)
        return f"@skill:{name}"   # keep the token visible in transcript

    expanded = pattern.sub(replace, raw)
    return expanded, loaded


