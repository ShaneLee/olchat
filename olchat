# Spinner
# ═══════════════════════════════════════════════════════════════════════════════

class Spinner:
    _FRAMES = "⣾⣽⣻⢿⡿⣟⣯⣷"

    def __init__(self, message: str = "Thinking…") -> None:
        self._message = message
        self._stop_event = threading.Event()
        self._thread = threading.Thread(target=self._spin, daemon=True)

    def _spin(self) -> None:
        i = 0
        while not self._stop_event.is_set():
            print(f"\r{self._FRAMES[i % 8]} {self._message}", end="", flush=True)
            i += 1
            time.sleep(0.08)

    def start(self) -> "Spinner":
        self._thread.start()
        return self

    def stop(self) -> None:
        self._stop_event.set()
        self._thread.join()
        print(f"\r{' ' * (len(self._message) + 3)}\r", end="", flush=True)
        sys.stdout.flush()

    def __enter__(self):  return self.start()
    def __exit__(self, *_): self.stop()


# ═══════════════════════════════════════════════════════════════════════════════
# Permissions
# ═══════════════════════════════════════════════════════════════════════════════
# Permission key:
#   shell:<command_stem>   e.g.  shell:ls   shell:git log   shell:git commit
#   write_file             (any write_file call)
#
# Persistence Model:
#   - GLOBAL permissions: stored persistently in ~/.ollama_chat_perms.json
#     These survive across all sessions and directories (user-wide)
#     Grant with 'g' option at permission prompt
#     Revoke with /revoke or by editing the JSON file
#
#   - SESSION permissions: stored in _session_perms dict (in-memory only)
#     Only active for the current run of the script
#     Grant with 's' option at permission prompt
#     Lost when the session ends
#
#   - ASK (default): prompt each time before allowing
#     No persistence — user must approve each action
#
# Permission flow when tool is called:
#   1. Check _session_perms (this session only)
#   2. Check PERMS_FILE (global permissions)
#   3. If neither allows, prompt user for: [y]es once, [s]ession, [g]lobal, [n]o

_session_perms: dict[str, str] = {}   # key → "allow"


def _load_global_perms() -> dict[str, str]:
    if PERMS_FILE.exists():
        try:
            return json.loads(PERMS_FILE.read_text())
        except Exception:
            return {}
    return {}


def _save_global_perms(perms: dict[str, str]) -> None:
    PERMS_FILE.write_text(json.dumps(perms, indent=2))


def _perm_key_for_shell(cmd: str) -> str:
    """
    Derive a permission key from a shell command string.
    'git log --oneline' → 'shell:git log'
    'ls -la'            → 'shell:ls'
    'rm -rf /'          → 'shell:rm'
    """
    parts = shlex.split(cmd)
    if not parts:
        return "shell:<empty>"
    stem = parts[0]
    # For multi-word tools like git, include the subcommand
    if stem == "git" and len(parts) > 1 and not parts[1].startswith("-"):
        stem = f"git {parts[1]}"
    return f"shell:{stem}"


def check_permission(key: str, description: str) -> bool:
    """
    Returns True if the action is permitted, False to deny.
    Prompts the user if needed and records the decision.
    """
    # Session allow?
    if _session_perms.get(key) == "allow":
        return True

    # Global allow?
    global_perms = _load_global_perms()
    if global_perms.get(key) == "allow":
        return True

    # Ask
    print(f"\n  ┌─ Permission required ───────────────────────────────")
    print(f"  │  Action : {description}")
    print(f"  │  Key    : {key}")
    print(f"  ├─────────────────────────────────────────────────────")
    print(f"  │  [y] Allow once")
    print(f"  │  [s] Allow for this session")
    print(f"  │  [g] Always allow (saved globally)")
    print(f"  │  [n] Deny")
    print(f"  └─────────────────────────────────────────────────────")

    while True:
        try:
            choice = input("  Choice [y/s/g/n]: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print("\n  [denied]")
            return False

        if choice == "y":
            return True
        elif choice == "s":
            _session_perms[key] = "allow"
            print(f"  [session: {key} allowed]")
            return True
        elif choice == "g":
            gp = _load_global_perms()
            gp[key] = "allow"
            _save_global_perms(gp)
            print(f"  [global: {key} saved to {PERMS_FILE}]")
            return True
        elif choice == "n":
            print("  [denied]")
            return False
        else:
            print("  Please enter y, s, g, or n.")


def revoke_permission(key: str) -> None:
    """Remove a global permission entry."""
    gp = _load_global_perms()
    removed = gp.pop(key, None)
    if removed:
        _save_global_perms(gp)
        print(f"[revoked global permission: {key}]")
    _session_perms.pop(key, None)
    print(f"[revoked session permission: {key}]" if key in _session_perms else "")


def list_permissions() -> None:
    gp = _load_global_perms()
    print("\n  Global permissions (stored in ~/.ollama_chat_perms.json):")
    if gp:
        for k, v in sorted(gp.items()):
            print(f"    {k} = {v}")
    else:
        print("    (none)")
    print("\n  Session permissions (this run only):")
    if _session_perms:
        for k, v in sorted(_session_perms.items()):
            print(f"    {k} = {v}")
    else:
        print("    (none)")
    print()


