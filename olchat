# Tool execution
# ═══════════════════════════════════════════════════════════════════════════════

TOOLS_SYSTEM_PROMPT = """
You have access to the following tools. Use them by outputting a fenced block:

~~~tool
{
  "tool": "<tool_name>",
  ... parameters ...
}
~~~

Available tools:

1. shell — run a shell command
   { "tool": "shell", "cmd": "ls -la src/" }

2. write_file — write content to a file
   { "tool": "write_file", "path": "foo.py", "content": "..." }

3. read_file — read a file (no permission needed)
   { "tool": "read_file", "path": "foo.py" }

4. task_add — add a sub-task to the queue
   { "tool": "task_add", "title": "Run tests", "detail": "pytest -x" }

5. task_done — mark a task complete
   { "tool": "task_done", "id": 3, "result": "all tests passed" }

6. task_list — list all tasks
   { "tool": "task_list" }

7. load_skill — load a skill by name into context (model uses this for auto-detection)
   { "tool": "load_skill", "name": "git" }

Rules:
- You MUST wait for the tool result before continuing.
- One tool call per fenced block.
- If a tool is denied, work around it or explain why you cannot proceed.
- After completing all tool calls needed for a task, summarise what was done.
"""


def run_tool(call: dict) -> str:
    """Dispatch a parsed tool call. Returns a result string for the model."""
    tool = call.get("tool", "")

    # ── shell ──────────────────────────────────────────────────────────────
    if tool == "shell":
        cmd = call.get("cmd", "").strip()
        if not cmd:
            return "[error: shell tool called with empty cmd]"

        key = _perm_key_for_shell(cmd)
        if not check_permission(key, f"shell: {cmd}"):
            return f"[denied: {cmd}]"

        print(f"\n  $ {cmd}")
        try:
            proc = subprocess.run(
                cmd, shell=True, capture_output=True, text=True, timeout=60
            )
            output = proc.stdout + proc.stderr
            if not output.strip():
                output = "(no output)"
            # Truncate very long output
            if len(output) > 4000:
                output = output[:4000] + "\n... [truncated]"
            print(output)
            return output
        except subprocess.TimeoutExpired:
            return "[error: command timed out after 60s]"
        except Exception as e:
            return f"[error: {e}]"

    # ── write_file ─────────────────────────────────────────────────────────
    elif tool == "write_file":
        path = call.get("path", "").strip()
        content = call.get("content", "")
        if not path:
            return "[error: write_file called with no path]"

        key = "write_file"
        if not check_permission(key, f"write file: {path}"):
            return f"[denied: write {path}]"

        try:
            p = Path(path)
            p.parent.mkdir(parents=True, exist_ok=True)
            p.write_text(content, encoding="utf-8")
            print(f"\n  [wrote {p} ({len(content)} bytes)]")
            return f"[wrote {path} successfully ({len(content)} bytes)]"
        except Exception as e:
            return f"[error writing {path}: {e}]"

    # ── read_file ──────────────────────────────────────────────────────────
    elif tool == "read_file":
        path = call.get("path", "").strip()
        if not path:
            return "[error: read_file called with no path]"
        p = Path(path)
        if not p.exists():
            return f"[error: {path} not found]"
        try:
            content = p.read_text(encoding="utf-8", errors="replace")
            if len(content) > 8000:
                content = content[:8000] + "\n... [truncated]"
            return content
        except Exception as e:
            return f"[error reading {path}: {e}]"

    # ── task_add ───────────────────────────────────────────────────────────
    elif tool == "task_add":
        title  = call.get("title", "untitled")
        detail = call.get("detail", "")
        new_id = task_add(title, detail)
        return f"[task #{new_id} added: {title}]"

    # ── task_done ──────────────────────────────────────────────────────────
    elif tool == "task_done":
        tid    = int(call.get("id", 0))
        result = call.get("result", "")
        task_done(tid, result)
        return f"[task #{tid} marked done]"

    # ── task_list ──────────────────────────────────────────────────────────
    elif tool == "task_list":
        tasks = task_list_all()
        if not tasks:
            return "(no tasks)"
        lines = []
        for t in tasks:
            lines.append(f"#{t['id']} [{t['status']}] {t['title']}")
            if t["detail"]:
                lines.append(f"   {t['detail']}")
            if t["result"]:
                lines.append(f"   → {t['result']}")
        return "\n".join(lines)

    # ── load_skill ────────────────────────────────────────────────────────
    elif tool == "load_skill":
        name = call.get("name", "").strip()
        if not name:
            return "[error: load_skill called with no name]"
        skill = find_skill(name)
        if skill is None:
            return f"[error: skill {name!r} not found in {SKILLS_DIR}]"
        return format_skill_block(skill)

    else:
        return f"[error: unknown tool '{tool}']"


_TOOL_BLOCK_RE = re.compile(r"~~~tool\s*(\{.*?\})\s*~~~", re.DOTALL)


def extract_tool_calls(text: str) -> list[tuple[str, dict]]:
    """
    Find all ~~~tool { ... } ~~~ blocks in text.
    Returns list of (raw_block, parsed_dict).
    """
    results = []
    for m in _TOOL_BLOCK_RE.finditer(text):
        raw = m.group(0)
        try:
            parsed = json.loads(m.group(1))
            results.append((raw, parsed))
        except json.JSONDecodeError as e:
            results.append((raw, {"tool": "__parse_error__", "error": str(e)}))
    return results


